{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mediause.dev/schemas/skill.schema.json",
  "title": "MediaUse Skill Definition",
  "description": "Canonical schema for a portable MediaUse skill definition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "description",
    "entry",
    "actions"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "description": "Entry file path for the skill runtime."
    },
    "runtime": {
      "type": "string",
      "enum": ["node", "python", "wasm"],
      "default": "node"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./action.schema.json"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
