{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mediause.dev/schemas/action.schema.json",
  "title": "MediaUse Action Definition",
  "description": "Canonical schema for a MediaUse action contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "input",
    "output"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "description": "JSON Schema for action input payload.",
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "description": "JSON Schema for action output payload.",
      "additionalProperties": true
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 0,
      "default": 30000
    },
    "retry": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
