{
  "name": "mediause",
  "version": "0.1.1",
  "description": "Power AI agents with native media control",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mediause-core-bootstrap": "dist/adapters/cli/postinstall.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "bootstrap:cli": "node ./scripts/postinstall.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\""
  },
  "keywords": [
    "mediause",
    "sdk",
    "workflow",
    "scheduler",
    "automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
